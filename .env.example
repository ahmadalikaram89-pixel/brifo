ANTHROPIC_API_KEY=sk-ant-...

# Web push (appointment reminders that fire even when the app is closed).
# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact address the push services may use to reach you about this app, e.g. mailto:you@example.com
VAPID_SUBJECT=

# Storage for push subscriptions + scheduled reminders. Point these at a
# Vercel KV / Upstash Redis REST endpoint in production. Left empty, the
# server falls back to an in-memory store that only works for local dev
# (data is lost on every restart / serverless cold start).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared secret checked by /api/cron/send-reminders. Vercel sends it
# automatically as `Authorization: Bearer $CRON_SECRET` for its own Cron
# Jobs once this is set. On the Hobby plan (which only allows daily cron),
# an external pinger (e.g. cron-job.org) hitting
# /api/cron/send-reminders?secret=... every ~15 min is a viable substitute.
CRON_SECRET=

# Password checked by /api/admin/ratings (the in-app user-ratings viewer at
# /admin). Left empty, that route is open to anyone — set this in production.
ADMIN_SECRET=
